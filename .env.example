# Statamic AI Assistant — environment variables
# Copy the relevant blocks into the host Laravel app's .env file.

# ─────────────────────────────────────────────────────────────────────────────
# Required: pick a provider and supply its credentials
# ─────────────────────────────────────────────────────────────────────────────

# infomaniak (CH, data residency) — or — groq (US, speed)
STATAMIC_AI_ASSISTANT_PROVIDER_NAME=infomaniak

# Infomaniak — required when STATAMIC_AI_ASSISTANT_PROVIDER_NAME=infomaniak
# Find your product id in the Infomaniak dashboard (Computing → AI Tools).
INFOMANIAK_PRODUCT_ID=
INFOMANIAK_API_TOKEN=
# INFOMANIAK_MODEL=qwen3

# Groq — required when STATAMIC_AI_ASSISTANT_PROVIDER_NAME=groq
# GROQ_API_KEY=
# GROQ_MODEL=llama-3.1-8b-instant

# https://jina.ai/reader — sent as Authorization: Bearer {key}.
# Without a key the URL fetch tool / migration crawl will be rate-limited.
STATAMIC_AI_ASSISTANT_JINA_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# Optional: Figma OAuth (design context for the entry generator)
# ─────────────────────────────────────────────────────────────────────────────
# Create an app at https://www.figma.com/developers/apps and register the
# redirect URL shown in the BOLD agent settings page.
# STATAMIC_AI_ASSISTANT_FIGMA_OAUTH_CLIENT_ID=
# STATAMIC_AI_ASSISTANT_FIGMA_OAUTH_CLIENT_SECRET=

# ─────────────────────────────────────────────────────────────────────────────
# Optional: feature flags
# ─────────────────────────────────────────────────────────────────────────────
# STATAMIC_AI_ASSISTANT_TRANSLATIONS=true            # per-entry + per-field translate
# STATAMIC_AI_ASSISTANT_BULK_TRANSLATIONS=true       # CP "Bulk translations" tool
# STATAMIC_AI_ASSISTANT_ENTRY_GENERATOR=true         # CP "Entry generator" tool
# STATAMIC_AI_ASSISTANT_MIGRATION_ENABLED=true       # CP "Website migration" tool

# ─────────────────────────────────────────────────────────────────────────────
# Advanced: tuning (defaults are sensible — only set if you hit a limit)
# ─────────────────────────────────────────────────────────────────────────────
# HTTP timeouts (seconds)
# STATAMIC_AI_ASSISTANT_INFOMANIAK_HTTP_TIMEOUT=600
# STATAMIC_AI_ASSISTANT_GROQ_HTTP_TIMEOUT=600
# STATAMIC_AI_ASSISTANT_JINA_TIMEOUT=120

# Queued entry generation (requires QUEUE_CONNECTION != sync)
# STATAMIC_AI_ASSISTANT_ENTRY_GENERATOR_QUEUE=default
# STATAMIC_AI_ASSISTANT_ENTRY_GENERATOR_JOB_TIMEOUT=300
# STATAMIC_AI_ASSISTANT_ENTRY_GENERATOR_JOB_TRIES=2

# Planner output ceiling (raise if listings get truncated to a single entry)
# STATAMIC_AI_ASSISTANT_PLANNER_MAX_OUTPUT_TOKENS=12000

# Migration crawl + asset caps
# STATAMIC_AI_ASSISTANT_MIGRATION_QUEUE=default
# STATAMIC_AI_ASSISTANT_MIGRATION_MAX_PAGES=500
# STATAMIC_AI_ASSISTANT_MIGRATION_CRAWL_DEPTH=3
# STATAMIC_AI_ASSISTANT_MIGRATION_ASSET_CONTAINER=